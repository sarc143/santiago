#!/bin/bash
# santiago — live macOS resource optimizer for 8GB Apple Silicon Macs
# Safe, reversible, no system file modifications. Ever.

set -euo pipefail

SANTIAGO_DIR="$HOME/.santiago"
LOG_FILE="$SANTIAGO_DIR/santiago.log"
CONFIG_FILE="$SANTIAGO_DIR/config"
PLIST_PATH="$HOME/Library/LaunchAgents/com.santiago.daemon.plist"
SCRIPT_PATH="$SANTIAGO_DIR/santiago"
REMOTE_URL="https://raw.githubusercontent.com/sarc143/santiago/master/santiago"

# Defaults
PURGE_THRESHOLD=40
CRITICAL_THRESHOLD=20
BATTERY_PURGE_THRESHOLD=50
INTERVAL=300
AGGRESSIVE=false
CPU_HOG_THRESHOLD=80
WHITELIST=""

# Load config overrides if they exist
[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

# --- Helpers ---

log() {
    local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $1"
    echo "$msg" >> "$LOG_FILE" 2>/dev/null
    # Rotate log if > 1MB
    if [[ -f "$LOG_FILE" ]] && (( $(wc -c < "$LOG_FILE") > 1048576 )); then
        tail -500 "$LOG_FILE" > "$LOG_FILE.tmp" && mv "$LOG_FILE.tmp" "$LOG_FILE"
    fi
}

print_fire() {
    echo "  🔥 santiago — live resource optimizer"
    echo ""
}

get_memory_free_pct() {
    memory_pressure 2>/dev/null | grep "System-wide memory free percentage" | awk '{print $NF}' | tr -d '%'
}

get_cpu_hogs() {
    # User-owned processes using more than threshold % CPU
    ps -arcwwwxo pid,user,%cpu,%mem,command 2>/dev/null | \
        awk -v user="$(whoami)" -v thresh="$CPU_HOG_THRESHOLD" \
        'NR>1 && $2==user && $3+0 > thresh {print}'
}

get_memory_hogs() {
    # Top 5 user-owned processes by memory
    ps -arcwwwxo pid,user,%cpu,%mem,command 2>/dev/null | \
        awk -v user="$(whoami)" 'NR>1 && $2==user' | \
        sort -k4 -rn | head -5
}

get_battery_info() {
    pmset -g batt 2>/dev/null
}

is_on_battery() {
    pmset -g batt 2>/dev/null | grep -q "Battery Power"
}

get_thermal_pressure() {
    pmset -g therm 2>/dev/null | grep -i "cpu_scheduler_limit\|speed_limit" || echo "Normal"
}

get_gpu_info() {
    ioreg -r -d 1 -c IOAccelerator 2>/dev/null | grep -E "PerformanceStatistics|\"Device Utilization" || echo "  No GPU stats available"
}

daemon_running() {
    launchctl list 2>/dev/null | grep -q "com.santiago.daemon"
}

# Run a command with sudo if a TTY is available for password prompts.
# When running as a daemon (no TTY), attempt the command without sudo first,
# then try sudo non-interactively (-n). Returns 1 if neither works.
try_sudo() {
    if [[ -t 0 ]]; then
        sudo "$@"
    else
        "$@" 2>/dev/null || sudo -n "$@" 2>/dev/null
    fi
}

# --- Commands ---

cmd_status() {
    print_fire

    # Memory
    local mem_free
    mem_free=$(get_memory_free_pct)
    local mem_color="\033[32m" # green
    if [[ -n "$mem_free" ]]; then
        if (( mem_free < CRITICAL_THRESHOLD )); then
            mem_color="\033[31m" # red
        elif (( mem_free < PURGE_THRESHOLD )); then
            mem_color="\033[33m" # yellow
        fi
        echo -e "  RAM:     ${mem_color}${mem_free}% free\033[0m"
    else
        echo "  RAM:     (unable to read memory pressure)"
    fi

    # CPU hogs
    local hogs
    hogs=$(get_cpu_hogs)
    if [[ -n "$hogs" ]]; then
        echo "  CPU:     ⚠ processes above ${CPU_HOG_THRESHOLD}%:"
        echo "$hogs" | while read -r line; do echo "           $line"; done
    else
        echo "  CPU:     all clear (nothing above ${CPU_HOG_THRESHOLD}%)"
    fi

    # Battery
    local batt
    batt=$(get_battery_info | tail -1 | sed 's/^[[:space:]]*/  Battery: /')
    echo "$batt"

    # Thermal
    local therm
    therm=$(get_thermal_pressure)
    echo "  Thermal: $therm"

    # GPU
    echo "  GPU:"
    get_gpu_info | head -5 | while read -r line; do echo "           $line"; done

    # Daemon status
    echo ""
    if daemon_running; then
        echo "  Daemon:  ✓ running (every ${INTERVAL}s)"
    else
        echo "  Daemon:  ✗ not running (use 'santiago start')"
    fi
    echo ""
}

cmd_burn() {
    local dry_run=false
    local aggressive=false

    for arg in "$@"; do
        case "$arg" in
            --dry-run) dry_run=true ;;
            --aggressive) aggressive=true ;;
        esac
    done

    if $dry_run; then
        echo "  🔥 santiago burn --dry-run (no actions will be taken)"
        echo ""
    fi

    local mem_free
    mem_free=$(get_memory_free_pct)
    local threshold=$PURGE_THRESHOLD

    # Use tighter threshold on battery
    if is_on_battery; then
        threshold=$BATTERY_PURGE_THRESHOLD
        $dry_run && echo "  [info] On battery — using tighter threshold (${threshold}%)"
        log "On battery power — threshold adjusted to ${threshold}%"
    fi

    # --- RAM ---
    if [[ -n "$mem_free" ]]; then
        echo "  RAM: ${mem_free}% free (threshold: ${threshold}%)"

        if (( mem_free < threshold )); then
            if $dry_run; then
                echo "  [would] Run 'sudo purge' to free inactive memory"
            else
                echo "  [action] Purging inactive memory..."
                try_sudo purge && echo "  [done] Memory purged" || echo "  [skip] purge requires sudo — run with sudo or enter password"
                log "Purged memory (was ${mem_free}% free, threshold ${threshold}%)"
            fi
        else
            echo "  [ok] Memory pressure is fine, no purge needed"
        fi

        if (( mem_free < CRITICAL_THRESHOLD )); then
            echo "  [warn] CRITICAL memory pressure — top memory consumers:"
            get_memory_hogs | while read -r line; do echo "           $line"; done
            log "CRITICAL memory: ${mem_free}% free. Top hogs logged."
        fi
    else
        echo "  [skip] Could not read memory pressure"
    fi

    # --- CPU ---
    local hogs
    hogs=$(get_cpu_hogs)
    if [[ -n "$hogs" ]]; then
        echo ""
        echo "  CPU hogs (>${CPU_HOG_THRESHOLD}%):"
        # Build burn-protected list from whitelist
        local burn_protected="Screenshot|ScreenCaptureKit|screencaptureui|screencapture|CleanShot|Shottr|Lightshot|Skitch|Monosnap|Snagit|Xnapper|ShareShot|Bartender|Ice|iStatMenus|MenubarX|Hidden Bar|Dozer|Vanilla"
        if [[ -n "$WHITELIST" ]]; then
            burn_protected="${burn_protected}|${WHITELIST}"
        fi

        echo "$hogs" | while read -r pid user cpu mem cmd; do
            echo "    PID $pid: $cmd (${cpu}% CPU, ${mem}% MEM)"

            # Skip whitelisted apps
            if printf '%s\n' "$cmd" | grep -qiE "$burn_protected"; then
                echo "    [skip] $cmd is whitelisted"
                continue
            fi

            if $aggressive || [[ "$AGGRESSIVE" == "true" ]]; then
                if $dry_run; then
                    echo "    [would] SIGSTOP PID $pid ($cmd) — resume with: kill -CONT $pid"
                else
                    kill -STOP "$pid" 2>/dev/null && \
                        echo "    [action] Paused PID $pid ($cmd) — resume with: kill -CONT $pid" || \
                        echo "    [skip] Could not pause PID $pid"
                    log "SIGSTOP sent to PID $pid ($cmd, ${cpu}% CPU)"
                fi
            fi
        done
    else
        echo ""
        echo "  CPU: all clear"
    fi

    # --- Thermal ---
    local therm
    therm=$(get_thermal_pressure)
    if printf '%s\n' "$therm" | grep -qi "limit\|throttle"; then
        echo ""
        echo "  [warn] Thermal throttling detected: $therm"
        log "Thermal throttling: $therm"
    fi

    echo ""
    log "Burn completed (mem_free=${mem_free}%, dry_run=${dry_run}, aggressive=${aggressive})"
}

cmd_start() {
    if daemon_running; then
        echo "  Santiago daemon is already running. Use 'santiago stop' first to restart."
        return 0
    fi

    # Create the plist
    cat > "$PLIST_PATH" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.santiago.daemon</string>
    <key>ProgramArguments</key>
    <array>
        <string>${SCRIPT_PATH}</string>
        <string>burn</string>
    </array>
    <key>StartInterval</key>
    <integer>${INTERVAL}</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${SANTIAGO_DIR}/daemon.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>${SANTIAGO_DIR}/daemon.stderr.log</string>
    <key>Nice</key>
    <integer>10</integer>
</dict>
</plist>
PLIST

    launchctl bootstrap "gui/$(id -u)" "$PLIST_PATH" 2>/dev/null || \
        launchctl load "$PLIST_PATH" 2>/dev/null

    echo "  🔥 Santiago daemon started (running burn every ${INTERVAL}s)"
    echo "  Stop with: santiago stop"
    log "Daemon started (interval=${INTERVAL}s)"
}

cmd_stop() {
    if ! daemon_running; then
        echo "  Santiago daemon is not running."
        return 0
    fi

    launchctl bootout "gui/$(id -u)/com.santiago.daemon" 2>/dev/null || \
        launchctl unload "$PLIST_PATH" 2>/dev/null
    rm -f "$PLIST_PATH"

    echo "  Santiago daemon stopped and removed."
    log "Daemon stopped"
}

cmd_log() {
    if [[ -f "$LOG_FILE" ]]; then
        tail -50 "$LOG_FILE"
    else
        echo "  No log file yet. Run 'santiago burn' first."
    fi
}

cmd_uninstall() {
    echo "  Uninstalling santiago..."

    # Stop daemon if running
    if daemon_running; then
        launchctl bootout "gui/$(id -u)/com.santiago.daemon" 2>/dev/null || \
            launchctl unload "$PLIST_PATH" 2>/dev/null
        echo "  ✓ Daemon stopped"
    fi

    # Remove plist
    rm -f "$PLIST_PATH"
    echo "  ✓ LaunchAgent removed"

    # Remove config/logs
    rm -rf "$SANTIAGO_DIR"
    echo "  ✓ ~/.santiago/ removed"

    echo ""
    echo "  Santiago fully uninstalled. Zero traces."
    echo "  (You can delete the script manually if it's elsewhere)"
}

cmd_nuke() {
    local dry_run=false
    [[ "${1:-}" == "--dry-run" ]] && dry_run=true

    echo "  ☢️  santiago nuke — scorched earth memory reclaim"
    echo ""

    local mem_before
    mem_before=$(get_memory_free_pct)
    echo "  RAM now: ${mem_before}% free"
    echo ""

    # Bare minimum protection — only stuff that would break your session
    # Also protect screenshot tools and menubar utilities by default
    local protected="Finder|WindowServer|SystemUIServer|Dock|loginwindow|santiago|bash|zsh|ssh|tmux|screen"
    protected="${protected}|Screenshot|ScreenCaptureKit|screencaptureui|screencapture"
    protected="${protected}|CleanShot|Shottr|Lightshot|Skitch|Monosnap|Snagit|Xnapper|ShareShot"
    protected="${protected}|Bartender|Ice|iStatMenus|MenubarX|Hidden Bar|Dozer|Vanilla"
    # Append user whitelist if set
    if [[ -n "$WHITELIST" ]]; then
        protected="${protected}|${WHITELIST}"
    fi

    # ═══ Phase 1: Non-destructive (no confirmation needed) ═══
    echo "  ═══ Phase 1: Memory & system flush ═══"
    echo ""

    # Purge RAM
    if $dry_run; then
        echo "  [would] Purge all inactive memory"
    else
        echo "  [action] Purging all inactive memory..."
        try_sudo purge && echo "  [done] Memory purged" || echo "  [skip] purge needs sudo"
        log "NUKE: Memory purged"
    fi

    # Flush DNS
    if $dry_run; then
        echo "  [would] Flush DNS cache"
    else
        echo "  [action] Flushing DNS cache..."
        try_sudo dscacheutil -flushcache && try_sudo killall -HUP mDNSResponder && \
            echo "  [done] DNS flushed" || echo "  [skip] DNS flush needs sudo"
        log "NUKE: DNS cache flushed"
    fi

    # SIGSTOP all CPU hogs (respecting whitelist)
    local cpu_hogs
    cpu_hogs=$(get_cpu_hogs)
    if [[ -n "$cpu_hogs" ]]; then
        echo ""
        echo "  [action] Pausing CPU hogs (>${CPU_HOG_THRESHOLD}%):"
        echo "$cpu_hogs" | while read -r pid user cpu mem cmd; do
            if printf '%s\n' "$cmd" | grep -qiE "$protected"; then
                echo "    [skip] $cmd (PID $pid) is protected"
                continue
            fi
            if $dry_run; then
                echo "    [would] SIGSTOP $cmd (PID $pid, ${cpu}% CPU)"
            else
                kill -STOP "$pid" 2>/dev/null && \
                    echo "    ⏸ $cmd (PID $pid, ${cpu}%) — resume: kill -CONT $pid" || true
                log "NUKE: SIGSTOP PID $pid ($cmd)"
            fi
        done
    fi

    echo ""

    # ═══ Phase 2: App killzone (interactive) ═══
    echo "  ═══ Phase 2: App killzone ═══"
    echo ""

    local user_procs
    user_procs=$(ps -axo pid,user,%mem,command 2>/dev/null | \
        awk -v user="$(whoami)" -v prot="$protected" \
        'BEGIN { split(prot, arr, "|"); for (i in arr) protmap[arr[i]]=1 }
         NR>1 && $2==user {
            mem=$3
            fullcmd=""
            for (i=4; i<=NF; i++) fullcmd = fullcmd (i>4?" ":"") $i
            n=split(fullcmd, parts, "/")
            name=parts[n]
            if (fullcmd ~ /\.app\//) {
                tmp = fullcmd
                sub(/\.app\/.*/, "", tmp)
                n2 = split(tmp, pp, "/")
                if (n2 > 0 && pp[n2] != "") name = pp[n2]
            }
            skip=0
            for (p in protmap) { if (name ~ p || fullcmd ~ p) { skip=1; break } }
            if (!skip && fullcmd !~ /^\/usr\/|^\/System\/|^\/sbin\/|com\.apple\./) print $1, name, mem
        }')

    if [[ -n "$user_procs" ]]; then
        # Group by app name, sum memory, sort biggest hogs first
        local app_groups
        app_groups=$(echo "$user_procs" | awk '{
            name=$2; pid=$1; mem=$3+0
            if (!(name in pids)) { order[++n]=name }
            pids[name] = pids[name] " " pid
            cnt[name]++
            totmem[name] += mem
        } END {
            for (i=1; i<=n; i++) print totmem[order[i]] "\t" order[i] "\t" cnt[order[i]] "\t" pids[order[i]]
        }' | sort -rn | cut -f2-)

        local total
        total=$(echo "$user_procs" | wc -l | tr -d ' ')

        # Load into simple indexed arrays
        local i=0
        local names="" counts="" pidlists="" statuses=""
        while IFS=$'\t' read -r aname acount apids; do
            [[ -z "$aname" ]] && continue
            names="${names}${aname}"$'\n'
            counts="${counts}${acount}"$'\n'
            pidlists="${pidlists}${apids}"$'\n'
            statuses="${statuses} "$'\n'  # space = alive
            i=$((i + 1))
        done <<< "$app_groups"

        local app_count=$i

        if $dry_run; then
            echo "  Found ${app_count} apps (${total} processes)"
            echo ""
            i=0
            while IFS= read -r aname; do
                [[ -z "$aname" ]] && continue
                local acount
                acount=$(echo "$counts" | sed -n "$((i+1))p")
                echo "    💣 $aname ($acount procs)"
                i=$((i + 1))
            done <<< "$names"
        else
            # --- Interactive TUI selector ---
            local cursor=0

            # Save/restore terminal state for clean exit
            local saved_tty
            saved_tty=$(stty -g </dev/tty 2>/dev/null)

            cleanup_tui() {
                tput cnorm 2>/dev/null
                stty "$saved_tty" </dev/tty 2>/dev/null
                echo ""
            }
            trap cleanup_tui EXIT
            trap 'cleanup_tui; exit 130' INT TERM

            tput civis 2>/dev/null  # hide cursor

            echo "  Found ${app_count} apps (${total} processes)"
            echo ""
            echo "  ↑↓ navigate  ⏎ nuke  a nuke all  q done"
            echo ""

            # Print all rows with newlines first to claim screen space
            local idx=0
            while (( idx < app_count )); do
                local aname acount
                aname=$(echo "$names" | sed -n "$((idx+1))p")
                acount=$(echo "$counts" | sed -n "$((idx+1))p")
                if (( idx == 0 )); then
                    printf "  \033[1m> 💣 %s (%s procs)\033[0m\n" "$aname" "$acount"
                else
                    printf "    💣 %s (%s procs)\n" "$aname" "$acount"
                fi
                idx=$((idx + 1))
            done

            # Now save position AFTER the list (we'll move up from here)
            # We know the list is app_count lines above current pos

            # Redraw a single row in-place
            draw_row() {
                local idx=$1
                local aname acount astatus
                aname=$(echo "$names" | sed -n "$((idx+1))p")
                acount=$(echo "$counts" | sed -n "$((idx+1))p")
                astatus=$(echo "$statuses" | sed -n "$((idx+1))p")
                # Move up from bottom of list to the target row
                local up=$(( app_count - idx ))
                printf "\033[s"  # save current pos
                printf "\033[%dA\r" "$up"  # move up to target row
                tput el 2>/dev/null  # clear line
                if [[ "$astatus" == "NUKED" ]]; then
                    if (( idx == cursor )); then
                        printf "  \033[31m> ☠️  %s (%s procs) (NUKED)\033[0m" "$aname" "$acount"
                    else
                        printf "    \033[31m☠️  %s (%s procs) (NUKED)\033[0m" "$aname" "$acount"
                    fi
                else
                    if (( idx == cursor )); then
                        printf "  \033[1m> 💣 %s (%s procs)\033[0m" "$aname" "$acount"
                    else
                        printf "    💣 %s (%s procs)" "$aname" "$acount"
                    fi
                fi
                printf "\033[u"  # restore pos back to bottom
            }

            # Full redraw (for nuke-all)
            draw_all() {
                local idx=0
                while (( idx < app_count )); do
                    draw_row "$idx"
                    idx=$((idx + 1))
                done
            }

            # Read keys
            while true; do
                local key
                IFS= read -rsn1 key </dev/tty

                if [[ "$key" == $'\x1b' ]]; then
                    local seq
                    IFS= read -rsn2 seq </dev/tty
                    case "$seq" in
                        '[A') # Up
                            if (( cursor > 0 )); then
                                local old=$cursor
                                cursor=$((cursor - 1))
                                draw_row "$old"
                                draw_row "$cursor"
                            fi
                            ;;
                        '[B') # Down
                            if (( cursor < app_count - 1 )); then
                                local old=$cursor
                                cursor=$((cursor + 1))
                                draw_row "$old"
                                draw_row "$cursor"
                            fi
                            ;;
                    esac
                elif [[ "$key" == "" ]]; then
                    # Enter — nuke selected app
                    local sel_status
                    sel_status=$(echo "$statuses" | sed -n "$((cursor+1))p")
                    if [[ "$sel_status" != "NUKED" ]]; then
                        local sel_name sel_pids
                        sel_name=$(echo "$names" | sed -n "$((cursor+1))p")
                        sel_pids=$(echo "$pidlists" | sed -n "$((cursor+1))p")
                        for p in $sel_pids; do kill "$p" 2>/dev/null || true; done
                        sleep 0.3
                        for p in $sel_pids; do kill -9 "$p" 2>/dev/null || true; done
                        statuses=$(echo "$statuses" | awk -v line="$((cursor+1))" 'NR==line{print "NUKED"; next}{print}')
                        log "NUKE: Killed $sel_name (PIDs: $sel_pids)"
                        draw_row "$cursor"
                    fi
                elif [[ "$key" == "a" || "$key" == "A" ]]; then
                    # Nuke everything
                    local idx=0
                    while (( idx < app_count )); do
                        local astatus
                        astatus=$(echo "$statuses" | sed -n "$((idx+1))p")
                        if [[ "$astatus" != "NUKED" ]]; then
                            local apids
                            apids=$(echo "$pidlists" | sed -n "$((idx+1))p")
                            local aname
                            aname=$(echo "$names" | sed -n "$((idx+1))p")
                            for p in $apids; do kill "$p" 2>/dev/null || true; done
                            log "NUKE: Killed $aname (PIDs: $apids)"
                        fi
                        idx=$((idx + 1))
                    done
                    sleep 0.5
                    idx=0
                    while (( idx < app_count )); do
                        local astatus
                        astatus=$(echo "$statuses" | sed -n "$((idx+1))p")
                        if [[ "$astatus" != "NUKED" ]]; then
                            local apids
                            apids=$(echo "$pidlists" | sed -n "$((idx+1))p")
                            for p in $apids; do kill -9 "$p" 2>/dev/null || true; done
                        fi
                        idx=$((idx + 1))
                    done
                    local new_statuses=""
                    for (( idx=0; idx<app_count; idx++ )); do
                        new_statuses="${new_statuses}NUKED"$'\n'
                    done
                    statuses="$new_statuses"
                    draw_all
                elif [[ "$key" == "q" || "$key" == "Q" ]]; then
                    break
                fi
            done

            cleanup_tui
            trap - EXIT INT TERM
        fi
    else
        echo "  [ok] No killable user processes found"
    fi

    echo ""

    # ═══ Results ═══
    if ! $dry_run; then
        sleep 2
        local mem_after
        mem_after=$(get_memory_free_pct)
        local reclaimed=$((mem_after - mem_before))
        echo "  ═══ Results ═══"
        echo ""
        echo "  RAM before: ${mem_before}% free"
        echo "  RAM after:  ${mem_after}% free"
        if (( reclaimed > 0 )); then
            echo "  Reclaimed:  ~${reclaimed}% of total memory"
        fi
        echo ""
        log "NUKE complete: ${mem_before}% → ${mem_after}% free (reclaimed ~${reclaimed}%)"
    else
        echo "  [dry-run complete — no actions taken]"
        echo ""
    fi
}

cmd_whitelist() {
    print_fire
    echo "  Apps on this list are safe from santiago. It will never close or pause them."
    echo ""

    # Built-in protected apps (always safe, can't be removed)
    local builtin_protected="Screenshot|ScreenCaptureKit|screencaptureui|screencapture|CleanShot|Shottr|Lightshot|Skitch|Monosnap|Snagit|Xnapper|ShareShot|Bartender|Ice|iStatMenus|MenubarX|Hidden Bar|Dozer|Vanilla"

    # Parse current user whitelist into an array
    local user_wl_items=()
    if [[ -n "$WHITELIST" ]]; then
        IFS='|' read -ra user_wl_items <<< "$WHITELIST"
    fi

    # --- Show current whitelist ---
    echo "  ── Currently protected (built-in) ──"
    echo ""
    # Check which built-in ones are actually installed
    local builtin_found=0
    IFS='|' read -ra builtin_arr <<< "$builtin_protected"
    for app in "${builtin_arr[@]}"; do
        # Check if running or installed in /Applications
        local found=false
        if pgrep -iq "$app" 2>/dev/null; then
            found=true
        elif ls /Applications/ 2>/dev/null | grep -qi "$app"; then
            found=true
        elif ls /Applications/Utilities/ 2>/dev/null | grep -qi "$app"; then
            found=true
        fi
        if $found; then
            echo "    ✓ $app (built-in, always protected)"
            builtin_found=$((builtin_found + 1))
        fi
    done
    if (( builtin_found == 0 )); then
        echo "    (none of the default screenshot/menubar tools are installed)"
    fi
    echo ""

    if (( ${#user_wl_items[@]} > 0 )); then
        echo "  ── Your whitelist ──"
        echo ""
        for app in "${user_wl_items[@]}"; do
            [[ -z "$app" ]] && continue
            echo "    ✓ $app"
        done
        echo ""
    fi

    # If just viewing (no subcommand), show the list and hint at add
    local subcmd="${1:-}"
    if [[ "$subcmd" != "add" && "$subcmd" != "remove" ]]; then
        echo "  ── Apps on your Mac you could protect ──"
        echo ""

        # Discover user apps: running user processes + /Applications
        # Exclude system stuff, already-protected stuff, and shells
        local all_protected="Finder|WindowServer|SystemUIServer|Dock|loginwindow|santiago|bash|zsh|ssh|tmux|screen|${builtin_protected}"
        if [[ -n "$WHITELIST" ]]; then
            all_protected="${all_protected}|${WHITELIST}"
        fi

        # Get running user apps (similar logic to nuke's process discovery)
        local running_apps
        running_apps=$(ps -axo pid,user,command 2>/dev/null | \
            awk -v user="$(whoami)" -v prot="$all_protected" \
            'BEGIN { split(prot, arr, "|"); for (i in arr) protmap[arr[i]]=1 }
             NR>1 && $2==user {
                fullcmd=""
                for (i=3; i<=NF; i++) fullcmd = fullcmd (i>3?" ":"") $i
                name=""
                if (fullcmd ~ /\.app\//) {
                    tmp = fullcmd
                    sub(/\.app\/.*/, "", tmp)
                    n2 = split(tmp, pp, "/")
                    if (n2 > 0 && pp[n2] != "") name = pp[n2]
                }
                if (name == "") {
                    n = split(fullcmd, parts, "/")
                    name = parts[n]
                    sub(/ .*/, "", name)
                }
                if (name == "" || length(name) < 2) next
                skip=0
                for (p in protmap) { if (name == p || tolower(name) == tolower(p)) { skip=1; break } }
                if (!skip && fullcmd !~ /^\/usr\/|^\/System\/|^\/sbin\/|com\.apple\./) print name
            }' | sort -u)

        # Also scan /Applications for .app bundles not currently running
        local installed_apps
        installed_apps=$(ls -1 /Applications/ 2>/dev/null | grep '\.app$' | sed 's/\.app$//' | while read -r appname; do
            # Skip if already protected
            if printf '%s\n' "$appname" | grep -qiE "$all_protected"; then
                continue
            fi
            echo "$appname"
        done)

        # Merge and deduplicate
        local all_addable
        all_addable=$(printf "%s\n%s" "$running_apps" "$installed_apps" | grep -v '^$' | sort -uf)

        if [[ -z "$all_addable" ]]; then
            echo "    (no additional apps found to whitelist)"
            echo ""
            return 0
        fi

        # Load into arrays for the TUI
        local app_names=()
        local app_statuses=()
        while IFS= read -r aname; do
            [[ -z "$aname" ]] && continue
            app_names+=("$aname")
            app_statuses+=(" ")
        done <<< "$all_addable"

        local app_count=${#app_names[@]}

        if (( app_count == 0 )); then
            echo "    (no additional apps found to whitelist)"
            echo ""
            return 0
        fi

        echo "  Found ${app_count} apps. Pick which ones to protect."
        echo ""
        echo "  ↑↓ navigate  ⏎ toggle protection  s save & exit  q quit without saving"
        echo ""

        # --- Interactive TUI selector ---
        local cursor=0

        local saved_tty
        saved_tty=$(stty -g </dev/tty 2>/dev/null)

        cleanup_wl_tui() {
            tput cnorm 2>/dev/null
            stty "$saved_tty" </dev/tty 2>/dev/null
            echo ""
        }
        trap cleanup_wl_tui EXIT
        trap 'cleanup_wl_tui; exit 130' INT TERM

        tput civis 2>/dev/null

        # Initial draw
        local idx=0
        while (( idx < app_count )); do
            if (( idx == 0 )); then
                printf "  \033[1m>   %s\033[0m\n" "${app_names[$idx]}"
            else
                printf "      %s\n" "${app_names[$idx]}"
            fi
            idx=$((idx + 1))
        done

        draw_wl_row() {
            local idx=$1
            local up=$(( app_count - idx ))
            printf "\033[s"
            printf "\033[%dA\r" "$up"
            tput el 2>/dev/null
            local marker="  "
            if [[ "${app_statuses[$idx]}" == "ADDED" ]]; then
                marker="✓ "
            fi
            if (( idx == cursor )); then
                if [[ "${app_statuses[$idx]}" == "ADDED" ]]; then
                    printf "  \033[32;1m> %s%s\033[0m" "$marker" "${app_names[$idx]}"
                else
                    printf "  \033[1m> %s%s\033[0m" "$marker" "${app_names[$idx]}"
                fi
            else
                if [[ "${app_statuses[$idx]}" == "ADDED" ]]; then
                    printf "    \033[32m%s%s\033[0m" "$marker" "${app_names[$idx]}"
                else
                    printf "    %s%s" "$marker" "${app_names[$idx]}"
                fi
            fi
            printf "\033[u"
        }

        while true; do
            local key
            IFS= read -rsn1 key </dev/tty

            if [[ "$key" == $'\x1b' ]]; then
                local seq
                IFS= read -rsn2 seq </dev/tty
                case "$seq" in
                    '[A')
                        if (( cursor > 0 )); then
                            local old=$cursor
                            cursor=$((cursor - 1))
                            draw_wl_row "$old"
                            draw_wl_row "$cursor"
                        fi
                        ;;
                    '[B')
                        if (( cursor < app_count - 1 )); then
                            local old=$cursor
                            cursor=$((cursor + 1))
                            draw_wl_row "$old"
                            draw_wl_row "$cursor"
                        fi
                        ;;
                esac
            elif [[ "$key" == "" ]]; then
                # Toggle
                if [[ "${app_statuses[$cursor]}" == "ADDED" ]]; then
                    app_statuses[$cursor]=" "
                else
                    app_statuses[$cursor]="ADDED"
                fi
                draw_wl_row "$cursor"
            elif [[ "$key" == "s" || "$key" == "S" ]]; then
                # Save — build new whitelist from existing + newly toggled
                local new_items=()
                # Keep existing user whitelist items
                for item in "${user_wl_items[@]}"; do
                    [[ -n "$item" ]] && new_items+=("$item")
                done
                # Add newly selected
                for (( idx=0; idx<app_count; idx++ )); do
                    if [[ "${app_statuses[$idx]}" == "ADDED" ]]; then
                        new_items+=("${app_names[$idx]}")
                    fi
                done

                # Build pipe-separated string
                local new_whitelist=""
                for item in "${new_items[@]}"; do
                    if [[ -z "$new_whitelist" ]]; then
                        new_whitelist="$item"
                    else
                        new_whitelist="${new_whitelist}|${item}"
                    fi
                done

                # Write to config
                if [[ -f "$CONFIG_FILE" ]]; then
                    if grep -q '^WHITELIST=' "$CONFIG_FILE"; then
                        sed -i '' "s|^WHITELIST=.*|WHITELIST=\"${new_whitelist}\"|" "$CONFIG_FILE" 2>/dev/null || \
                            sed -i "s|^WHITELIST=.*|WHITELIST=\"${new_whitelist}\"|" "$CONFIG_FILE" 2>/dev/null
                    else
                        echo "WHITELIST=\"${new_whitelist}\"" >> "$CONFIG_FILE"
                    fi
                else
                    echo "WHITELIST=\"${new_whitelist}\"" > "$CONFIG_FILE"
                fi

                cleanup_wl_tui
                trap - EXIT INT TERM

                local added_count=0
                for (( idx=0; idx<app_count; idx++ )); do
                    [[ "${app_statuses[$idx]}" == "ADDED" ]] && added_count=$((added_count + 1))
                done

                echo ""
                if (( added_count > 0 )); then
                    echo "  ✓ Saved! ${added_count} app(s) added to your whitelist."
                else
                    echo "  ✓ Whitelist saved (no new apps added)."
                fi
                if [[ -n "$new_whitelist" ]]; then
                    echo "  Protected: ${new_whitelist//|/, }"
                fi
                echo ""
                log "Whitelist updated: ${new_whitelist}"
                return 0
            elif [[ "$key" == "q" || "$key" == "Q" ]]; then
                break
            fi
        done

        cleanup_wl_tui
        trap - EXIT INT TERM
        echo "  (no changes saved)"
        echo ""
        return 0
    fi

    # --- santiago whitelist remove ---
    if [[ "$subcmd" == "remove" ]]; then
        if (( ${#user_wl_items[@]} == 0 )); then
            echo "  Your whitelist is empty — nothing to remove."
            echo ""
            return 0
        fi

        local remove_target="${2:-}"
        if [[ -z "$remove_target" ]]; then
            echo "  Usage: santiago whitelist remove <AppName>"
            echo ""
            echo "  Your current whitelist:"
            for app in "${user_wl_items[@]}"; do
                [[ -n "$app" ]] && echo "    - $app"
            done
            echo ""
            return 0
        fi

        # Rebuild without the target
        local new_items=()
        local removed=false
        for item in "${user_wl_items[@]}"; do
            if [[ "${item,,}" == "${remove_target,,}" ]]; then
                removed=true
            else
                [[ -n "$item" ]] && new_items+=("$item")
            fi
        done

        if ! $removed; then
            echo "  '$remove_target' is not in your whitelist."
            echo ""
            return 1
        fi

        local new_whitelist=""
        for item in "${new_items[@]}"; do
            if [[ -z "$new_whitelist" ]]; then
                new_whitelist="$item"
            else
                new_whitelist="${new_whitelist}|${item}"
            fi
        done

        if grep -q '^WHITELIST=' "$CONFIG_FILE" 2>/dev/null; then
            sed -i '' "s|^WHITELIST=.*|WHITELIST=\"${new_whitelist}\"|" "$CONFIG_FILE" 2>/dev/null || \
                sed -i "s|^WHITELIST=.*|WHITELIST=\"${new_whitelist}\"|" "$CONFIG_FILE" 2>/dev/null
        fi

        echo "  ✓ Removed '$remove_target' from your whitelist."
        echo ""
        log "Whitelist: removed $remove_target"
    fi
}

cmd_update() {
    print_fire
    echo "  Checking for updates..."
    echo ""

    # Figure out where we're installed
    local self
    self="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"

    # Download latest to a temp file
    local tmpfile
    tmpfile=$(mktemp "${TMPDIR:-/tmp}/santiago-update.XXXXXX")
    trap "rm -f -- \"${tmpfile}\"" RETURN

    # Build curl args — add auth if available (needed for private repos, avoids rate limits)
    local curl_args=(-fsSL -o "$tmpfile")
    if [[ -n "${GITHUB_TOKEN:-}" ]]; then
        curl_args+=(-H "Authorization: token ${GITHUB_TOKEN}")
    elif command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
        local gh_token
        gh_token=$(gh auth token 2>/dev/null)
        if [[ -n "$gh_token" ]]; then
            curl_args+=(-H "Authorization: token ${gh_token}")
        fi
    fi

    if ! curl "${curl_args[@]}" "$REMOTE_URL" 2>/dev/null; then
        echo "  ✗ Couldn't reach GitHub. Check your internet and try again."
        echo ""
        return 1
    fi

    # Verify it's actually a script (basic sanity check)
    if ! head -1 "$tmpfile" | grep -q '^#!/bin/bash'; then
        echo "  ✗ Downloaded file doesn't look right. Update aborted."
        echo ""
        return 1
    fi

    # Compare with current version
    if diff -q "$self" "$tmpfile" >/dev/null 2>&1; then
        echo "  ✓ Already up to date. You're running the latest version."
        echo ""
        return 0
    fi

    # Show what changed (brief summary)
    local added removed
    added=$(diff "$self" "$tmpfile" 2>/dev/null | grep -c '^>' || true)
    removed=$(diff "$self" "$tmpfile" 2>/dev/null | grep -c '^<' || true)
    echo "  New version available (+${added} -${removed} lines)"
    echo ""

    # Install — may need sudo depending on where we're installed
    if [[ -w "$self" ]]; then
        cp "$tmpfile" "$self"
        chmod +x "$self"
        echo "  ✓ Updated! santiago is now the latest version."
    elif try_sudo cp "$tmpfile" "$self" && try_sudo chmod +x "$self"; then
        echo "  ✓ Updated! (used sudo since ${self} isn't writable by you)"
    else
        echo "  ✗ Couldn't write to ${self}. Try:"
        echo "    sudo santiago update"
        echo ""
        return 1
    fi

    echo ""

    # Restart daemon if it's running so it picks up the new version
    if daemon_running; then
        echo "  Restarting background daemon with new version..."
        cmd_stop >/dev/null 2>&1
        cmd_start >/dev/null 2>&1
        echo "  ✓ Daemon restarted."
        echo ""
    fi

    log "Updated santiago from GitHub"
}

cmd_help() {
    print_fire
    echo "  Your Mac only has 8GB of RAM. Santiago keeps it from choking."
    echo ""
    echo "  Just type 'santiago' and one of these:"
    echo ""
    echo "    status       How's my Mac doing right now?"
    echo "    burn         Free up memory (quick clean, nothing gets closed)"
    echo "    nuke         Pick which apps to force-quit, one by one"
    echo "    whitelist    See and pick which apps santiago should never touch"
    echo "    start        Run santiago in the background every 5 min"
    echo "    stop         Turn off the background thing"
    echo "    log          See what santiago has been doing"
    echo "    update       Grab the latest version from GitHub"
    echo "    uninstall    Get rid of santiago completely"
    echo ""
    echo "  Examples:"
    echo "    santiago status        # check if your Mac is struggling"
    echo "    santiago burn           # quick fix, frees up memory"
    echo "    santiago nuke           # the big one — pick apps to kill"
    echo "    santiago nuke --dry-run # see what it WOULD kill (safe to run)"
    echo "    santiago start          # set it and forget it"
    echo ""
    echo "  Whitelist:"
    echo "    santiago whitelist         # see protected apps + pick new ones"
    echo "    santiago whitelist remove AppName  # unprotect an app"
    echo "    Screenshot tools and menubar utilities are always protected."
    echo ""
    echo "  Nothing santiago does is permanent. It never deletes files."
    echo "  Worst case: an app you closed reopens itself. That's it."
    echo ""
}

# --- Main ---

/bin/mkdir -p "$SANTIAGO_DIR"

case "${1:-}" in
    status)   cmd_status ;;
    burn)     shift; cmd_burn "$@" ;;
    nuke)     shift; cmd_nuke "$@" ;;
    whitelist) shift; cmd_whitelist "$@" ;;
    start)    cmd_start ;;
    stop)     cmd_stop ;;
    log)      cmd_log ;;
    update)    cmd_update ;;
    uninstall) cmd_uninstall ;;
    help|--help|-h) cmd_help ;;
    *)        cmd_help ;;
esac
